<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/micCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:cardUseCompatPadding="false"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/container"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Collapsed state: Only the waveform icon -->
            <ImageView
                android:id="@+id/micIcon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:padding="16dp"
                android:src="@drawable/ic_waveform"
                app:tint="?attr/colorPrimary"
                android:visibility="visible" />

            <!-- Expanded state: Cancel, Recording Status, Confirm -->
            <LinearLayout
                android:id="@+id/expandedControls"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="4dp"
                android:visibility="gone">

                <!-- Cancel Button -->
                <ImageButton
                    android:id="@+id/btnCancel"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/circle_white"
                    android:backgroundTint="?attr/colorSurfaceVariant"
                    android:src="@drawable/ic_close"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="Abbrechen" />

                <!-- Recording / Progress Area -->
                <FrameLayout
                    android:id="@+id/statusArea"
                    android:layout_width="70dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/pill_white"
                    android:backgroundTint="?attr/colorPrimaryContainer">

                    <!-- Pulsing background when recording -->
                    <View
                        android:id="@+id/recordingPulse"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/pill_white"
                        android:backgroundTint="?attr/colorPrimary"
                        android:alpha="0" />

                    <ImageView
                        android:id="@+id/waveformAnim"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_waveform"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <ProgressBar
                        android:id="@+id/polishingProgress"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:indeterminate="true"
                        android:indeterminateTint="?attr/colorPrimary"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- Confirm Button -->
                <ImageButton
                    android:id="@+id/btnConfirm"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="4dp"
                    android:background="@drawable/circle_primary"
                    android:backgroundTint="?attr/colorPrimary"
                    android:src="@drawable/ic_check"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    app:tint="?attr/colorOnPrimary"
                    android:contentDescription="Bestätigen" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
